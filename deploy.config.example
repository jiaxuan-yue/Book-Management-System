# =============================================================================
# 部署 / SSH 统一配置（唯一入口）
# =============================================================================
# 本仓库只保留这一份 SSH 相关说明与配置模板。
# - 可提交：deploy.config.example（本文件）
# - 勿提交：复制为 deploy.config 后填写真实值（已加入 .gitignore）
# - 私钥只放本机 ~/.ssh 与 GitHub Secrets，禁止写入任何仓库文件
# =============================================================================

# ----- 服务器连接 -----
SERVER_HOST=你的服务器公网IP
SERVER_USER=root
SERVER_PORT=22
DEPLOY_PATH=/home/app

# ----- 本机密钥路径（不要把私钥内容写进本文件）-----
# 生成：ssh-keygen -t ed25519 -C "github-actions-deploy" -f ~/.ssh/deploy_key_book_mgmt -N ""
SSH_PRIVATE_KEY_FILE=~/.ssh/deploy_key_book_mgmt
SSH_PUBLIC_KEY_FILE=~/.ssh/deploy_key_book_mgmt.pub

# ----- GitHub Actions Secrets（与 .github/workflows/deploy.yml 对应）-----
# 仓库：Settings → Secrets and variables → Actions
# 或用命令（在填写好上面变量后执行）：
#
#   gh secret set SERVER_HOST  -R jiaxuan-yue/Book-Management-System -b "$SERVER_HOST"
#   gh secret set SERVER_USER  -R jiaxuan-yue/Book-Management-System -b "$SERVER_USER"
#   gh secret set SERVER_PORT  -R jiaxuan-yue/Book-Management-System -b "$SERVER_PORT"
#   gh secret set DEPLOY_PATH  -R jiaxuan-yue/Book-Management-System -b "$DEPLOY_PATH"
#   gh secret set SERVER_SSH_KEY -R jiaxuan-yue/Book-Management-System < "$SSH_PRIVATE_KEY_FILE"
#
# Secret 名称必须是：
#   SERVER_HOST / SERVER_USER / SERVER_PORT / SERVER_SSH_KEY / DEPLOY_PATH

# ----- 把公钥装到服务器（一次性）-----
#   PUB=$(cat ~/.ssh/deploy_key_book_mgmt.pub)
#   ssh root@你的IP "mkdir -p ~/.ssh && chmod 700 ~/.ssh && echo '$PUB' >> ~/.ssh/authorized_keys && chmod 600 ~/.ssh/authorized_keys"
#
# 本机登录测试：
#   ssh -i ~/.ssh/deploy_key_book_mgmt -p 22 root@你的IP

# ----- 轮换密钥（泄露后）-----
# 1. 生成本机新密钥对
# 2. 服务器 authorized_keys：删掉旧公钥行，追加新公钥
# 3. 重新执行上面的 gh secret set SERVER_SSH_KEY
# 4. 旧私钥本地改名或删除，勿再提交到 Git
